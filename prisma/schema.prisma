generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Authentication identity for the signed-in account.
model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  sessions      Session[]
  artistProfile ArtistProfile?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Core artist workspace that owns the music-business records for a user.
model ArtistProfile {
  id              String           @id @default(cuid())
  userId          String           @unique
  artistName      String
  genre           String?
  bio             String?
  goals           String[]         @default([])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  releases        Release[]
  campaigns       Campaign[]
  contentItems    ContentItem[]
  fans            Fan[]
  tasks           Task[]
  metricSnapshots MetricSnapshot[]

  @@index([artistName])
}

/// Release-level planning record for singles, EPs, and albums.
model Release {
  id              String        @id @default(cuid())
  artistProfileId String
  title           String
  slug            String
  type            ReleaseType
  status          ReleaseStatus
  releaseDate     DateTime?
  distributor     String?
  coverArtUrl     String?
  description     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  artistProfile   ArtistProfile @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  tracks          Track[]
  campaigns       Campaign[]
  contentItems    ContentItem[]

  @@unique([artistProfileId, slug])
  @@index([artistProfileId, status, releaseDate])
  @@index([artistProfileId, createdAt])
}

/// Track records allow a release to carry granular delivery metadata.
model Track {
  id              String      @id @default(cuid())
  releaseId       String
  title           String
  durationSeconds Int?
  isrc            String?
  versionName     String?
  status          TrackStatus
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  release         Release     @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([releaseId, status])
  @@index([isrc])
}

/// Campaigns can optionally map to a specific release while still supporting broader brand pushes.
model Campaign {
  id              String         @id @default(cuid())
  artistProfileId String
  releaseId       String?
  name            String
  objective       String
  budget          Int?
  startDate       DateTime
  endDate         DateTime?
  status          CampaignStatus
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  artistProfile   ArtistProfile  @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  release         Release?       @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  contentItems    ContentItem[]

  @@index([artistProfileId, status, startDate])
  @@index([releaseId])
}

/// Scheduled or published marketing content associated with a campaign and/or release.
model ContentItem {
  id              String         @id @default(cuid())
  artistProfileId String
  campaignId      String?
  releaseId       String?
  platform        ContentPlatform
  format          ContentFormat
  title           String
  caption         String?
  dueDate         DateTime
  publishedAt     DateTime?
  status          ContentStatus
  assetUrl        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  artistProfile   ArtistProfile  @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  campaign        Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  release         Release?       @relation(fields: [releaseId], references: [id], onDelete: SetNull)

  @@index([artistProfileId, status, dueDate])
  @@index([campaignId])
  @@index([releaseId])
}

/// Lightweight CRM record for a fan or supporter.
model Fan {
  id              String        @id @default(cuid())
  artistProfileId String
  name            String
  email           String?
  handle          String?
  city            String?
  tags            String[]      @default([])
  engagementScore Int           @default(0)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  artistProfile   ArtistProfile @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)

  @@index([artistProfileId, engagementScore])
  @@index([artistProfileId, createdAt])
  @@unique([artistProfileId, email])
}

/// General-purpose operational task that can point at another record by type and id.
model Task {
  id              String          @id @default(cuid())
  artistProfileId String
  relatedType     TaskRelatedType?
  relatedId       String?
  title           String
  description     String?
  dueDate         DateTime?
  priority        TaskPriority
  status          TaskStatus
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  artistProfile   ArtistProfile   @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)

  @@index([artistProfileId, status, dueDate])
  @@index([artistProfileId, relatedType, relatedId])
}

/// Time-series metric row keyed by source and metric name for flexible manual analytics imports.
model MetricSnapshot {
  id              String        @id @default(cuid())
  artistProfileId String
  source          MetricSource
  metricName      MetricName
  metricValue     Float
  recordedAt      DateTime
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  artistProfile   ArtistProfile @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)

  @@unique([artistProfileId, source, metricName, recordedAt])
  @@index([artistProfileId, source, metricName, recordedAt])
  @@index([artistProfileId, recordedAt])
}

enum ReleaseType {
  SINGLE
  EP
  ALBUM
}

enum ReleaseStatus {
  IDEA
  IN_PROGRESS
  SCHEDULED
  RELEASED
  ARCHIVED
}

enum TrackStatus {
  DRAFT
  MIXING
  MASTERED
  DISTRIBUTED
  RELEASED
  ARCHIVED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ContentPlatform {
  INSTAGRAM
  TIKTOK
  YOUTUBE
  EMAIL
  X
  OTHER
}

enum ContentFormat {
  SHORT_VIDEO
  STATIC_POST
  CAROUSEL
  STORY
  EMAIL_BLAST
  PRESS_ASSET
  OTHER
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum TaskRelatedType {
  RELEASE
  TRACK
  CAMPAIGN
  CONTENT_ITEM
  FAN
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}

enum MetricSource {
  SPOTIFY
  APPLE_MUSIC
  YOUTUBE
  INSTAGRAM
  TIKTOK
  MAILING_LIST
  MANUAL
}

enum MetricName {
  STREAMS
  FOLLOWERS
  ENGAGEMENT_RATE
  REVENUE_USD
  PRE_SAVES
  TICKET_SALES
  EMAIL_SUBSCRIBERS
}
